<Window x:Class="ClipyWin.Views.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clipy Preferences"
        Width="560" Height="480"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="0,6,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- GENERAL -->
            <TabItem x:Name="GeneralTab" Header="General">
                <StackPanel Margin="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Max history size:" Grid.Row="0" Grid.Column="0"/>
                        <TextBox x:Name="MaxHistoryBox" Grid.Row="0" Grid.Column="1" Width="100" HorizontalAlignment="Left"/>
                        <Label x:Name="LanguageLabel" Content="Language:" Grid.Row="1" Grid.Column="0"/>
                        <ComboBox x:Name="LanguageCombo" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0" DisplayMemberPath="Name" SelectedValuePath="Code"/>
                    </Grid>
                    <CheckBox x:Name="ReorderCheck" Content="Move pasted clip to top"/>
                    <CheckBox x:Name="LoginItemCheck" Content="Launch Clipy at login"/>
                    <CheckBox x:Name="OverwriteCheck" Content="Overwrite same history entry"/>
                    <CheckBox x:Name="CopySameCheck" Content="Record duplicate copies"/>
                    <TextBlock Margin="0,12,0,0" FontStyle="Italic" Foreground="#666"
                               Text="Language changes apply after restart."/>
                </StackPanel>
            </TabItem>

            <!-- MENU -->
            <TabItem x:Name="MenuTab" Header="Menu">
                <StackPanel Margin="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Items shown inline:"      Grid.Row="0" Grid.Column="0"/>
                        <TextBox x:Name="InlineBox"                Grid.Row="0" Grid.Column="1" Width="100" HorizontalAlignment="Left"/>
                        <Label Content="Items per sub-folder:"    Grid.Row="1" Grid.Column="0"/>
                        <TextBox x:Name="InFolderBox"             Grid.Row="1" Grid.Column="1" Width="100" HorizontalAlignment="Left"/>
                        <Label Content="Max title length:"        Grid.Row="2" Grid.Column="0"/>
                        <TextBox x:Name="MaxTitleBox"             Grid.Row="2" Grid.Column="1" Width="100" HorizontalAlignment="Left"/>
                        <Label Content="Tooltip max length:"      Grid.Row="3" Grid.Column="0"/>
                        <TextBox x:Name="MaxTooltipBox"           Grid.Row="3" Grid.Column="1" Width="100" HorizontalAlignment="Left"/>
                    </Grid>

                    <CheckBox x:Name="MarkedCheck"        Content="Number menu items"/>
                    <CheckBox x:Name="StartZeroCheck"     Content="Start numbering from 0"/>
                    <CheckBox x:Name="ShowTooltipCheck"   Content="Show tooltip on menu items"/>
                    <CheckBox x:Name="AddClearCheck"      Content="Show 'Clear History' item in menu"/>
                    <CheckBox x:Name="AlertClearCheck"    Content="Confirm before clearing history"/>
                </StackPanel>
            </TabItem>

            <!-- EXCLUDED APPS -->
            <TabItem x:Name="ExcludedTab" Header="Excluded Apps">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="Clipboard content copied while one of these applications is focused will not be stored. Enter the process name (without .exe)."/>
                    <ListBox Grid.Row="1" x:Name="ExcludeList"/>
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ExcludeInput" Grid.Column="0" Margin="0,0,8,0"/>
                        <Button x:Name="ExcludeAddBtn" Grid.Column="1" Content="Add" Padding="12,3" Click="ExcludeAdd_Click"/>
                        <Button x:Name="ExcludeRemoveBtn" Grid.Column="2" Margin="6,0,0,0" Content="Remove" Padding="12,3" Click="ExcludeRemove_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- SHORTCUTS -->
            <TabItem x:Name="ShortcutsTab" Header="Shortcuts">
                <StackPanel Margin="12">
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="Click a field, then press the desired key combo. Press Escape or Backspace to clear."/>
                    <Grid Margin="0,4,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="240"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Show history menu:"    Grid.Row="0" Grid.Column="0"/>
                        <TextBox x:Name="HistoryHotkeyBox"     Grid.Row="0" Grid.Column="1"
                                 IsReadOnly="True" Cursor="Hand"
                                 Text="Ctrl+Shift+V"
                                 PreviewKeyDown="Hotkey_PreviewKeyDown"
                                 Tag="history"/>

                        <Label Content="Show snippets menu:"   Grid.Row="1" Grid.Column="0"/>
                        <TextBox x:Name="SnippetHotkeyBox"     Grid.Row="1" Grid.Column="1"
                                 IsReadOnly="True" Cursor="Hand"
                                 PreviewKeyDown="Hotkey_PreviewKeyDown"
                                 Tag="snippets"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- UPDATES -->
            <TabItem x:Name="UpdatesTab" Header="Updates">
                <StackPanel Margin="12">
                    <TextBlock TextWrapping="Wrap"
                               Text="Configure a Velopack release feed URL to enable automatic updates. Leave empty to disable."/>
                    <Label Content="Update feed URL:" Margin="0,12,0,0"/>
                    <TextBox x:Name="UpdateUrlBox" />
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="CheckUpdateBtn" Content="Check for updates" Padding="12,4" Click="CheckUpdate_Click"/>
                        <Button x:Name="ApplyUpdateBtn" Content="Download &amp; restart" Padding="12,4" Margin="8,0,0,0" Click="ApplyUpdate_Click" IsEnabled="False"/>
                    </StackPanel>
                    <TextBlock x:Name="UpdateStatusText" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#444"/>
                    <TextBlock Margin="0,16,0,0" x:Name="VersionText" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CloseBtn" Content="Close" Width="90" Padding="0,4" IsCancel="True" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
