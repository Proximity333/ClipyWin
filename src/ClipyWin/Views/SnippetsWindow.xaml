<Window x:Class="ClipyWin.Views.SnippetsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snippets"
        Width="820" Height="560"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: folders + snippets tree -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TreeView x:Name="Tree"
                      Grid.Row="0"
                      SelectedItemChanged="Tree_SelectedItemChanged"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="+ Folder"  Padding="8,3" Click="AddFolder_Click"/>
                <Button Content="+ Snippet" Margin="6,0,0,0" Padding="8,3" Click="AddSnippet_Click" x:Name="AddSnippetBtn"/>
                <Button Content="Delete"    Margin="6,0,0,0" Padding="8,3" Click="Delete_Click" x:Name="DeleteBtn"/>
            </StackPanel>
        </Grid>

        <!-- RIGHT: editor -->
        <Grid Grid.Column="1" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Title" Margin="0,0,0,4"/>
            <TextBox   Grid.Row="1" x:Name="TitleBox" Padding="4,3" TextChanged="Title_Changed"/>
            <TextBox   Grid.Row="2" x:Name="ContentBox" Margin="0,10,0,0"
                       AcceptsReturn="True" AcceptsTab="True"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto"
                       FontFamily="Consolas" FontSize="13"
                       TextChanged="Content_Changed"/>

            <DockPanel Grid.Row="3" Margin="0,10,0,0" LastChildFill="False">
                <Button DockPanel.Dock="Left"  Content="Import XML..." Padding="10,3" Click="Import_Click"/>
                <Button DockPanel.Dock="Left"  Content="Export XML..." Margin="6,0,0,0" Padding="10,3" Click="Export_Click"/>
                <Button DockPanel.Dock="Right" Content="Close"          Padding="16,3" Click="Close_Click"/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
